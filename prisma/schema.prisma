// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// Role: USER (default) or ADMIN. Set via direct DB query, never from the app.
enum Role {
    USER
    ADMIN
}

model User {
    id               String           @id @default(cuid())
    name             String?
    email            String           @unique
    emailVerified    DateTime?
    image            String?
    role             Role             @default(USER)
    paddleCustomerId String?
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt
    // Referral fields
    referralCode     String           @unique @default(cuid())
    referredById     String?
    freeProUntil     DateTime?
    accounts         Account[]
    sessions         Session[]
    subscriptions    Subscription[]
    referredBy       User?            @relation("UserReferrals", fields: [referredById], references: [id])
    referrals        User[]           @relation("UserReferrals")
    rewardsGiven     ReferralReward[] @relation("ReferrerRewards")
    rewardsReceived  ReferralReward[] @relation("RefereeRewards")
}

model ReferralReward {
    id         String   @id @default(cuid())
    referrerId String
    refereeId  String
    createdAt  DateTime @default(now())
    referrer   User     @relation("ReferrerRewards", fields: [referrerId], references: [id])
    referee    User     @relation("RefereeRewards", fields: [refereeId], references: [id])

    @@unique([referrerId, refereeId])
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                   String   @id @default(cuid())
    userId               String
    paddleSubscriptionId String   @unique
    status               String
    currentPeriodEnd     DateTime
    createdAt            DateTime @default(now())
    updatedAt            DateTime @updatedAt
    user                 User     @relation(fields: [userId], references: [id])
}
