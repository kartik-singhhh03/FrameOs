# Copy this file to .env and fill in your values

# Neon Postgres — https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3002"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Paddle — https://vendors.paddle.com
# sandbox | production
PADDLE_ENV="sandbox"
# Server-side API key  (Developer Tools → Authentication)
PADDLE_API_KEY=""
# Webhook signing secret (Notifications → your endpoint → Secret key)
PADDLE_WEBHOOK_SECRET=""
# Price ID (Catalog → Prices)
PADDLE_PRICE_ID=""
# Client-side token (Developer Tools → Client-side tokens)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
